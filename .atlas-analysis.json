  "keyFeatures": [
    "Microservices architecture with Spring Boot and Eureka service discovery",
    "Role-based access control with JWT authentication (Admin, Producer, Driver)",
    "Client management with delivery route tracking",
    "Complete inventory management system with recipes and raw materials",
    "Delivery tracking and route optimization",
    "Real-time dashboards and reporting with charts",
    "Next.js frontend with responsive design",
    "Docker containerization and Render deployment support"
  ],
  "publicApiSurface": [
    "POST /api/usuarios/auth/login - User authentication",
    "GET /clientes - Get all clients",
    "POST /clientes - Create new client",
    "GET /usuarios - Get all users",
    "POST /usuarios - Create new user",
    "GET /productos - Get all products",
    "POST /productos - Create new product",
    "GET /materias-primas - Get raw materials",
    "POST /materias-primas - Create raw material",
    "GET /recetas - Get recipes",
    "POST /recetas - Create recipe",
    "GET /entregas - Get all deliveries",
    "POST /entregas - Create delivery",
    "GET /rutas - Get delivery routes",
    "POST /rutas - Create delivery route",
    "GET /lotes - Get production batches",
    "POST /lotes - Create production batch"
  ]
